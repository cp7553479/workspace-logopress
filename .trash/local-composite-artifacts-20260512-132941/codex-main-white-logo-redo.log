/bin/bash -lc "python3 - <<'PY'
from PIL import Image
from pathlib import Path
base_path = Path('/root/.openclaw/workspace-oss/.temp/LP0189-main-set/ref-white.png')
logo_path = Path('/root/.openclaw/workspace-oss/skills/asi-product-image-generator/asserts/LOGO-BK.png')
out_path = Path('/root/.openclaw/workspace-oss/.temp/LP0189-main-set/LP0189-main-white-logo-redo.png')

base = Image.open(base_path).convert('RGBA')
logo = Image.open(logo_path).convert('RGBA')

# Crop transparent padding from the logo asset.
alpha = logo.getchannel('A')
bbox = alpha.getbbox()
logo = logo.crop(bbox)

# Fit logo to the straight printable front face of the bottle without crossing the glass edges.
# The bottle body is about 350 px wide in a 1254 px canvas; use a restrained print width.
target_w = 255
target_h = round(logo.height * target_w / logo.width)
logo = logo.resize((target_w, target_h), Image.Resampling.LANCZOS)

# Printed-on-bottle appearance: solid black art, slight transparency so glass highlights remain natural.
r, g, b, a = logo.split()
print_alpha = a.point(lambda v: int(v * 0.88))
logo_print = Image.merge('RGBA', (r, g, b, print_alpha))

# Centered on front printable area, slightly above mid body, avoiding shoulder/base distortion.
x = (base.width - target_w) // 2
y = 520

composed = base.copy()
composed.alpha_composite(logo_print, (x, y))
out_path.parent.mkdir(parents=True, exist_ok=True)
composed.convert('RGB').save(out_path, 'PNG', optimize=True)
print(out_path)
print(Image.open(out_path).size)
